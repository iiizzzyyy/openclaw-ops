<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Botty (OpenClaw) Health Monitor -->
    <!-- Runs every 30 seconds to check Botty health -->
    
    <key>Label</key>
    <string>com.hermes.botty-monitor</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/izzy/ai-agents/hermes-tasks/botty_health_monitor.py</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/izzy/ai-agents</string>
    
    <key>RunAtLoad</key>
    <true/>
    
    <!-- Run every 5 minutes (300 seconds) to avoid GitHub rate limiting -->
    <key>StartInterval</key>
    <integer>300</integer>
    
    <!-- Standard output/error logging -->
    <key>StandardOutPath</key>
    <string>/Users/izzy/ai-agents/logs/botty-monitor.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/izzy/ai-agents/logs/botty-monitor-error.log</string>
    
    <!-- Environment -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HERMES_HOME</key>
        <string>/Users/izzy/.hermes</string>
    </dict>
    
    <!-- Don't run multiple instances -->
    <key>ThrottleInterval</key>
    <integer>25</integer>
</dict>
</plist>
